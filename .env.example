# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/campus-resource-hub

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here

# Cloudinary Configuration (Required for file uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Server Configuration
PORT=5000
NODE_ENV=development

# Client URL
CLIENT_URL=http://localhost:5173

# OpenAI AI Assistant
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Groq AI Assistant (free developer limits; set AI_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Hugging Face Inference Providers (set AI_PROVIDER=huggingface)
HUGGINGFACE_API_KEY=your_huggingface_token_here
HUGGINGFACE_MODEL=openai/gpt-oss-20b

# File Upload Configuration
MAX_FILE_SIZE=52428800
